# DataLens Environment Configuration
# Copy this file to `.env` and fill in your values.
# NEVER commit `.env` to git. Only `.env.example` (this file) is committed.

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------

# Which LLM provider should the app use?
# Valid values: gemini, anthropic, openai, groq
LLM_PROVIDER=gemini

# API keys — fill in ONLY the one matching your LLM_PROVIDER above.
# The others can remain blank.

# Google Gemini (free tier available) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq (free tier available) — https://console.groq.com/keys
GROQ_API_KEY=

# Optional: specify a particular model name for your chosen provider.
# If omitted, the app uses a reasonable default.
# LLM_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# Backend host and port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend development port
FRONTEND_PORT=5173

# SQLite database file path (relative to backend directory)
DATABASE_URL=sqlite:///./datalens.db

# Maximum CSV upload size in megabytes
MAX_UPLOAD_SIZE_MB=50

# -----------------------------------------------------------------------------
# Development Options (optional)
# -----------------------------------------------------------------------------

# Set to "true" to enable verbose logging
DEBUG=false

# CORS allowed origins for local development
CORS_ORIGINS=http://localhost:5173
